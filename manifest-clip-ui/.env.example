# API endpoint overrides (take priority over config.json and config.example.json)
# Copy this file to .env.local and uncomment the vars you want to override.

# Point at your deployed backend:
# REACT_APP_API_RECORDINGS=https://xxx.execute-api.region.amazonaws.com/Prod/getrecordings/
# REACT_APP_API_CLIPS=https://xxx.execute-api.region.amazonaws.com/Prod/getclips/
# REACT_APP_API_CLIPMANIFEST=https://xxx.execute-api.region.amazonaws.com/Prod/clipmanifest/

# Or point at the local mock server (default when using config.example.json):
# REACT_APP_API_RECORDINGS=http://localhost:3001/getrecordings/
# REACT_APP_API_CLIPS=http://localhost:3001/getclips/
# REACT_APP_API_CLIPMANIFEST=http://localhost:3001/clipmanifest/
